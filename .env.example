# SagaMind Environment Variables Configuration Template

# Server Configuration
ENV=development
HOST=0.0.0.0
PORT=8000
GRPC_PORT=50051

# Relational and Vector DB (TimescaleDB)
DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=sagamind
DB_USER=sagamind_user
DB_PASS=sagamind_secure_pass_2026

# Semantic Graph DB (Neo4j)
NEO4J_URI=bolt://127.0.0.1:7687
NEO4J_USER=neo4j
NEO4J_PASS=sagamind_secure_neo_2026

# Cache and Transaction Log Broker (Redis)
REDIS_HOST=127.0.0.1
REDIS_PORT=6379

# Z3 Theorem Solver CLI Path configuration
Z3_PATH=z3

# LLM Providers Configuration (For Vector Embeddings & Consolidation summarize loop)
OPENAI_API_KEY=your-sk-key-here
EMBEDDING_MODEL=text-embedding-3-small
CONSOLIDATION_MODEL=gpt-4
