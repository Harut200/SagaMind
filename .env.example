# SagaMind environment configuration template.
# Copy to `.env` and replace every secret below with a strong, unique value.
# In production (ENV=production) the process REFUSES TO START if any secret is
# left at a known development default or if API_KEYS is empty.

# ── Server ────────────────────────────────────────────────────────────
ENV=development
HOST=0.0.0.0
PORT=8000
GRPC_PORT=50051

# ── Security / API ────────────────────────────────────────────────────
# Comma-separated API keys. Empty => auth DISABLED (development only).
API_KEYS=
# Comma-separated CORS allow-list (e.g. https://app.example.com).
CORS_ORIGINS=
# Per-client requests/minute. 0 disables rate limiting.
RATE_LIMIT_PER_MINUTE=0
# Maximum request body size in bytes (default 1 MiB).
MAX_REQUEST_BYTES=1048576
# Filesystem jail for sandboxed writes (absolute path). Defaults to CWD.
ALLOWED_WORKSPACE_ROOT=
# Fail fast instead of falling back to in-memory emulators when a backend is down.
REQUIRE_BACKENDS=false

# ── TimescaleDB ───────────────────────────────────────────────────────
DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=sagamind
DB_USER=sagamind_user
DB_PASS=CHANGE_ME_strong_db_password

# ── Neo4j ─────────────────────────────────────────────────────────────
NEO4J_URI=bolt://127.0.0.1:7687
NEO4J_USER=neo4j
NEO4J_PASS=CHANGE_ME_strong_neo4j_password

# ── Redis ─────────────────────────────────────────────────────────────
REDIS_HOST=127.0.0.1
REDIS_PORT=6379

# ── Engine / LLM ──────────────────────────────────────────────────────
Z3_PATH=z3
Z3_TIMEOUT_MS=5000
OPENAI_API_KEY=
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIM=1536
CONSOLIDATION_MODEL=gpt-4
